{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Cucumber Tests (All)",
      "program": "${workspaceFolder}/node_modules/@cucumber/cucumber/bin/cucumber.js",
      "args": [
        "--config",
        "cucumber.js"
      ],
      "runtimeArgs": ["--nolazy"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PWDEBUG": "0"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Dashboard Tag (@dashboard)",
      "program": "${workspaceFolder}/node_modules/@cucumber/cucumber/bin/cucumber.js",
      "args": [
        "--config",
        "cucumber.js",
        "--tags",
        "@dashboard"
      ],
      "runtimeArgs": ["--nolazy"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PWDEBUG": "0"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Cucumber By Tag",
      "program": "${workspaceFolder}/node_modules/@cucumber/cucumber/bin/cucumber.js",
      "args": [
        "--config",
        "cucumber.js",
        "--tags",
        "${input:cucumberTag}"
      ],
      "runtimeArgs": ["--nolazy"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PWDEBUG": "0"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Current Feature File",
      "program": "${workspaceFolder}/node_modules/@cucumber/cucumber/bin/cucumber.js",
      "args": [
        "--config",
        "cucumber.js",
        "${file}"
      ],
      "runtimeArgs": ["--nolazy"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PWDEBUG": "0"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ],
  "inputs": [
    {
      "id": "cucumberTag",
      "type": "pickString",
      "description": "Choose Cucumber tag",
      "options": [
        "@dashboard",
        "@login",
        "@smoke",
        "@regression",
        "@negative"
      ],
      "default": "@dashboard"
    }
  ]
}