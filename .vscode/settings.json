{
    "editor.accessibilitySupport": "off",
    "files.associations": {
        "*.feature": "feature"
    },
    "vscode-cucumberjs-navigator.steps": [
        "tests/step-definitions/**/*.ts"
    ],
    "vscode-cucumberjs-navigator.featurePaths": [
        "tests/feature-files"
    ],
    "vscode-cucumberjs-navigator.StepFilesSuffixes": [
        "Steps.ts",
        ".steps.ts"
    ],

    "cucumberautocomplete.steps": [
        "tests/step-definitions/**/*.ts"
    ],
    "cucumberautocomplete.syncfeatures": "tests/feature-files/**/*.feature",
    "cucumberautocomplete.gherkinDefinitionPart": "(Given|When|Then|And|But|\\*)\\(",
    "cucumberautocomplete.strictGherkinCompletion": true,
    "cucumberautocomplete.strictGherkinValidation": true,
    "cucumberautocomplete.stepsInvariants": true,
    "cucumberautocomplete.smartSnippets": true,
    "cucumberautocomplete.onTypeFormat": true
}
