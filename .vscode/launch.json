      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ],
  "inputs": [
    {
      "id": "playwrightGrep",
      "type": "promptString",
      "description": "Enter Playwright grep pattern (e.g. @smoke|Login)",
      "default": "@smoke"
    }
  ]
}