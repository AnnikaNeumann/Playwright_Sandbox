{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: Current Spec (authenticated)",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": [
        "test",
        "${file}",
        "--project=authenticated",
        "--headed",
        "--workers=1",
        "--timeout=0"
      ],
      "runtimeArgs": ["--nolazy"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": { "PWDEBUG": "1" },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: Current Spec (unauthenticated)",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": [
        "test",
        "${file}",
        "--project=unauthenticated",
        "--headed",
        "--workers=1",
        "--timeout=0"
      ],
      "runtimeArgs": ["--nolazy"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": { "PWDEBUG": "1" },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
