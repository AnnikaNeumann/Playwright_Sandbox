{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Playwright (Current Spec)",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": [
        "test",
        "${file}",
        "--project=chromium",
        "--headed",
        "--workers=1"
      ],
      "runtimeArgs": ["--nolazy"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PWDEBUG": "1",
        "DEBUG_LOCATORS": "true"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Playwright (All Specs)",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": [
        "test",
        "tests/specs",
        "--project=chromium",
        "--headed",
        "--workers=1"
      ],
      "runtimeArgs": ["--nolazy"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PWDEBUG": "1",
        "DEBUG_LOCATORS": "true"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Playwright (By Grep Tag)",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": [
        "test",
        "--grep",
        "${input:playwrightGrep}",
        "--project=chromium",
        "--headed",
        "--workers=1"
      ],
      "runtimeArgs": ["--nolazy"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PWDEBUG": "1",
        "DEBUG_LOCATORS": "true"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Playwright (Dashboard Spec)",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": [
        "test",
        "tests/specs/dashboard.spec.ts",
        "--project=chromium",
        "--headed",
        "--workers=1"
      ],
      "runtimeArgs": ["--nolazy"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PWDEBUG": "1",
        "DEBUG_LOCATORS": "true"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ],
  "inputs": [
    {
      "id": "playwrightGrep",
      "type": "promptString",
      "description": "Enter Playwright grep pattern (e.g. @smoke|Login)",
      "options": [
      ],
      "default": "@smoke"
    }
  ]
}