      "name": "Debug: By Grep Tag",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": [
        "test",
        "--grep",
        "${input:playwrightGrep}",
        "--headed",
        "--workers=1",
        "--timeout=0"
